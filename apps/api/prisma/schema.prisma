generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COUNSELLOR
  TEACHER
  STUDENT
  PARENT
  FIREFLY_REPRESENTATIVE
  FIREFLY_SPECIALIST
  SYSTEM_ADMIN
}

enum Tier {
  TIER_1
  TIER_2
  TIER_3
}

enum StudentStatus {
  STABLE
  NEEDS_SUPPORT
  NEEDS_INTERVENTION
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  CLOSED
}

enum CaseType {
  SEL
  COUNSELLING
  CRISIS
  CAREER
  NEURO_DEVELOPMENTAL
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum IncidentSeverity {
  LOW
  MODERATE
  HIGH
  CRITICAL
}

enum LessonStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum WorkshopStatus {
  DRAFT
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum SelCategory {
  SELF_AWARENESS
  EMOTIONAL_REGULATION
  EMPATHY
  COMMUNICATION
  LEADERSHIP
  CONFLICT_RESOLUTION
  RESILIENCE
}

enum WorkshopCategory {
  BULLYING_PREVENTION
  CAREER_GUIDANCE
  MENTAL_HEALTH_AWARENESS
  DIGITAL_SAFETY
  STRESS_MANAGEMENT
  PARENT_AWARENESS
  TEACHER_WELLNESS
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  EXCUSED
}

model User {
  id                String              @id @default(uuid()) @db.Uuid
  email             String              @unique
  passwordHash      String
  fullName          String
  role              Role
  schoolId          String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  refreshTokens     RefreshToken[]
  openedCases       Case[]              @relation("OpenedBy")
  assignedCases     Case[]              @relation("AssignedCounsellor")
  sessions          Session[]           @relation("CounsellorSessions")
  incidentReports   Incident[]          @relation("ReportedIncidents")
  timelineEvents    CaseTimelineEvent[] @relation("TimelineCreatedBy")
  counsellorStudents Student[]          @relation("CounsellorStudents")
  facilitatedSelSessions SelSession[]   @relation("FacilitatedSelSessions")
  approvedLessons   SelLesson[]         @relation("ApprovedLessons")
  createdLessons SelLesson[]         @relation("CreatedLessons")
  createdTemplates SelLessonTemplate[]
  facilitator Facilitator?
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  tokenHash String
  userId    String   @db.Uuid
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Student {
  id              String         @id @default(uuid()) @db.Uuid
  admissionNumber String?        @unique
  firstName       String
  lastName        String
  grade           String
  classroom       String
  tier            Tier           @default(TIER_1)
  status          StudentStatus  @default(STABLE)
  riskScore       Int            @default(0)
  counsellorId    String?        @db.Uuid
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  counsellor      User?          @relation("CounsellorStudents", fields: [counsellorId], references: [id])
  assessments     Assessment[]
  cases           Case[]
  sessions        Session[]
  incidents       Incident[]

  @@index([grade, classroom])
  @@index([tier])
}

model Assessment {
  id         String    @id @default(uuid()) @db.Uuid
  studentId  String    @db.Uuid
  score      Int
  riskLevel  RiskLevel
  notes      String?
  createdAt  DateTime  @default(now())
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
}

model Case {
  id                   String              @id @default(uuid()) @db.Uuid
  studentId            String              @db.Uuid
  openedById           String              @db.Uuid
  assignedCounsellorId String?             @db.Uuid
  title                String
  summary              String?
  tier                 Tier
  type                 CaseType
  riskLevel            RiskLevel
  status               CaseStatus          @default(OPEN)
  openedAt             DateTime            @default(now())
  closedAt             DateTime?
  student              Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  openedBy             User                @relation("OpenedBy", fields: [openedById], references: [id])
  assignedCounsellor   User?               @relation("AssignedCounsellor", fields: [assignedCounsellorId], references: [id])
  timelineEvents       CaseTimelineEvent[]
  sessions             Session[]
  incidents            Incident[]

  @@index([studentId, status])
  @@index([tier, riskLevel])
}

model CaseTimelineEvent {
  id          String   @id @default(uuid()) @db.Uuid
  caseId      String   @db.Uuid
  createdById String   @db.Uuid
  eventType   String
  title       String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("TimelineCreatedBy", fields: [createdById], references: [id])

  @@index([caseId, createdAt])
}

model Session {
  id             String        @id @default(uuid()) @db.Uuid
  caseId         String?       @db.Uuid
  studentId      String        @db.Uuid
  counsellorId   String        @db.Uuid
  title          String
  notes          String?
  scheduledAt    DateTime
  durationMins   Int           @default(45)
  status         SessionStatus @default(SCHEDULED)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  case           Case?         @relation(fields: [caseId], references: [id], onDelete: SetNull)
  student        Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  counsellor     User          @relation("CounsellorSessions", fields: [counsellorId], references: [id])

  @@index([scheduledAt, status])
}

model Incident {
  id           String           @id @default(uuid()) @db.Uuid
  studentId    String?          @db.Uuid
  caseId       String?          @db.Uuid
  reportedById String           @db.Uuid
  severity     IncidentSeverity
  incidentType String
  description  String
  actionTaken  String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  student      Student?         @relation(fields: [studentId], references: [id], onDelete: SetNull)
  case         Case?            @relation(fields: [caseId], references: [id], onDelete: SetNull)
  reportedBy   User             @relation("ReportedIncidents", fields: [reportedById], references: [id])

  @@index([severity, createdAt])
}

model Classroom {
  id          String     @id @default(uuid()) @db.Uuid
  schoolId    String
  name        String
  grade       String
  section     String?
  students    Student[]  @relation("ClassroomStudents")
  teachers    ClassroomTeacher[]
  timetable   TimetableSlot[]
  selSessions SelSession[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([schoolId, name])
  @@index([grade, section])
}

model ClassroomTeacher {
  id          String   @id @default(uuid()) @db.Uuid
  classroomId String   @db.Uuid
  teacherId   String   @db.Uuid
  isClassTeacher Boolean @default(false)
  assignedAt  DateTime @default(now())

  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  teacher     User      @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([classroomId, teacherId])
  @@index([teacherId])
}

model TimetableSlot {
  id          String   @id @default(uuid()) @db.Uuid
  classroomId String   @db.Uuid
  dayOfWeek   Int      // 0=Monday .. 6=Sunday
  period      Int
  subject     String
  teacherId   String?  @db.Uuid
  startTime   DateTime?
  endTime     DateTime?
  isSelSlot   Boolean  @default(false)

  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  teacher     User?     @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  @@index([classroomId, dayOfWeek, period])
}

model Observation {
  id          String   @id @default(uuid()) @db.Uuid
  studentId   String   @db.Uuid
  createdById String   @db.Uuid
  context     String?  // free text context like date/time/place
  category    String   // Academic | Behavioural | Emotional
  note        String
  isFlag      Boolean  @default(false)
  createdAt   DateTime @default(now())

  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
}

model Flag {
  id           String   @id @default(uuid()) @db.Uuid
  observationId String? @db.Uuid
  studentId    String   @db.Uuid
  raisedById   String   @db.Uuid
  category     String   // Academic | Behavioural | Emotional
  status       String   @default("OPEN")
  resolutionNote String?
  raisedAt     DateTime @default(now())
  resolvedAt   DateTime?

  observation  Observation? @relation(fields: [observationId], references: [id], onDelete: SetNull)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  raisedBy     User         @relation(fields: [raisedById], references: [id], onDelete: Cascade)

  @@index([studentId, status])
}

model IEP {
  id           String   @id @default(uuid()) @db.Uuid
  studentId    String   @db.Uuid
  uploadedById String   @db.Uuid
  title        String
  documentUrl  String
  consentLogged Boolean @default(false)
  consentGivenById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  consentGivenBy User?  @relation(fields: [consentGivenById], references: [id], onDelete: SetNull)

  @@index([studentId])
}

model SelSession {
  id           String        @id @default(uuid()) @db.Uuid
  lessonId     String?       @db.Uuid
  classroomId  String        @db.Uuid
  title        String
  topic        String
  scheduledAt  DateTime
  durationMins Int           @default(45)
  facilitatorId String       @db.Uuid
  status       SessionStatus @default(SCHEDULED)
  feedback     Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  lesson          SelLesson?     @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  classroom       Classroom      @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  facilitator     Facilitator    @relation(fields: [facilitatorId], references: [id], onDelete: Cascade)
  attendance      SelSessionAttendance[]
  feedbackEntries SelSessionFeedback[]

  @@index([classroomId, scheduledAt])
}

model SelLessonTemplate {
  id String      @id @default(uuid()) @db.Uuid
  title             String
  grade             String
  category          SelCategory
  durationMins      Int         @default(45)
  learningObjectives String[]
  activities Json
  reflectionQuestions String[]
  createdById       String      @db.Uuid
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  lessons    SelLesson[] @relation
  createdBy  User        @relation(fields: [createdById], references: [id])
}

model SelLesson {
  id                   String        @id @default(uuid()) @db.Uuid
  templateId           String?       @db.Uuid
  title String
  grade                String
  topic                String
  category             SelCategory
  learningObjectives   String[]
  activities           Json
  reflectionQuestions String[]
  durationMins         Int           @default(45)
  status               LessonStatus  @default(DRAFT)
  approvedById         String?       @db.Uuid
  approvedAt           DateTime?
  rejectionReason     String?
  createdById          String        @db.Uuid
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  template    SelLessonTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  approvedBy  User?              @relation("ApprovedLessons", fields: [approvedById], references: [id])
  createdBy   User               @relation("CreatedLessons", fields: [createdById], references: [id])
  selSessions SelSession[]
}

model WorkshopTemplate {
  id           String           @id @default(uuid()) @db.Uuid
  title        String
  description  String
  category     WorkshopCategory
  audience     String
  durationMins Int @default(90)
  materials    String[]
  createdById  String           @db.Uuid
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  workshops  Workshop[]
  createdBy  User      @relation(fields: [createdById], references: [id])
}

model Workshop {
  id             String         @id @default(uuid()) @db.Uuid
  templateId     String?        @db.Uuid
  title          String
  description    String
  category       WorkshopCategory
  audience       String
  venue String
  date           DateTime
  durationMins   Int            @default(90)
  facilitatorId  String        @db.Uuid
  materials String[]
  status         WorkshopStatus @default(DRAFT)
  feedbackScore  Float?
  createdById    String        @db.Uuid
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  template   WorkshopTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  facilitator Facilitator          @relation(fields: [facilitatorId], references: [id])
  createdBy   User                 @relation(fields: [createdById], references: [id])
  attendance WorkshopAttendance[]
  feedback   WorkshopFeedback[]
}

model Facilitator {
  id String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  fullName  String
  email     String
  expertise String[]
  type      String
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User? @relation(fields: [userId], references: [id])
  selSessions  SelSession[]
  workshops    Workshop[]
}

model SelSessionAttendance {
  id String           @id @default(uuid()) @db.Uuid
  sessionId String @db.Uuid
  studentId String           @db.Uuid
  status    AttendanceStatus @default(PRESENT)
  createdAt DateTime        @default(now())

  session SelSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
}

model SelSessionFeedback {
  id              String   @id @default(uuid()) @db.Uuid
  sessionId       String   @db.Uuid
  respondentName  String?
  usefulnessScore Int
  learnedNew      Boolean
  wouldRecommend Boolean
  rating          Int
  comments        String?
  submittedAt     DateTime @default(now())

  session SelSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model WorkshopAttendance {
  id           String           @id @default(uuid()) @db.Uuid
  workshopId   String           @db.Uuid
  studentId    String?          @db.Uuid
  attendeeName String?
  status       AttendanceStatus @default(PRESENT)
  createdAt    DateTime        @default(now())

  workshop Workshop  @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  student  Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@unique([workshopId, studentId])
}

model WorkshopFeedback {
  id              String   @id @default(uuid()) @db.Uuid
  workshopId      String   @db.Uuid
  respondentName  String?
  usefulnessScore Int
  learnedNew      Boolean
  wouldRecommend Boolean
  rating          Int
  comments        String?
  submittedAt     DateTime @default(now())

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
}
